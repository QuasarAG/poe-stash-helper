# Personal runtime state — keep local, do not push to GitHub
data/config.json
data/loadouts.json

# Virtual environments
.venv/
venv/
env/

# Test / coverage output
.coverage
htmlcov/
.pytest_cache/

# Build artifacts
build/
dist/
*.egg-info/

# Qt / IDE extras
.idea/